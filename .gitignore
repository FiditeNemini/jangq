# Models & weights
models/
# Allow JANGStudio Swift Models source folder (case-insensitive match above would block it)
!JANGStudio/JANGStudio/Models/
*.whl
*.tar.gz
*.safetensors

# Python
.venv/
__pycache__/
*.egg-info/
.pytest_cache/
build/
dist/
.pypirc

# Research & experiments (PRIVATE — never publish)
research/

# Per-session investigation + bench notes (PRIVATE — never publish).
# Contains architectural findings, kernel speed measurements, and
# comparison data that competitors reproduced from past public notes.
docs/superpowers/notes/

# Internal docs
JANG-ISSUES.md
JANG-PLAN.md
gemma4_*.md

# Scripts (private experiments)
scripts/
# Allow JANGStudio build scripts (build-python-bundle, codesign, notarize)
!JANGStudio/Scripts/
crack_*.py
probe_*.py
benchmark_*.py
run_*
eval_*
sweep*
debug_*
test_*
# Allow ralph_runner test suite
!ralph_runner/tests/test_*.py
# Allow ralph_runner fixtures (deterministic test assets)
!ralph_runner/fixtures/test_image.png
!ralph_runner/fixtures/test_video_frames.npy
repack_*
ram_monitor*

# Logs & results
mmlu_results*
*.log

# Build artifacts
jang-runtime/.build/
jang-runtime/.swiftpm/
jang-tools/build/

# Environment & config
.env
.env.*
.DS_Store
.claude/
.playwright-mcp/

# Server (private)
jang-server/

# Experimental quantization modules (private R&D)
jang-tools/jang_tools/calibrate_fp8.py
jang-tools/jang_tools/convert_mxrq.py
jang-tools/jang_tools/convert_mxtq.py
jang-tools/jang_tools/convert_mxtq_to_jang.py
jang-tools/jang_tools/gptq_mlx.py
jang-tools/jang_tools/load_mxrq.py
jang-tools/jang_tools/load_mxtq.py
jang-tools/jang_tools/turboquant/

# Vectors (experimental)
vectors/

# JANGStudio
JANGStudio/build/
JANGStudio/JANGStudio.xcodeproj/xcuserdata/
JANGStudio/DerivedData/
.superpowers/

# Ralph Runner private outputs
ralph_runner/results/
ralph_runner/baselines/
ralph_runner/.venv/
ralph_runner/*.log
